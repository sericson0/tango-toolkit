---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Tools and resources for tango DJs. Software and guides to elevate your tango DJing.", ogImage = "/images/Logo.png" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/Logo.png" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={`${title} | The Tango Toolkit`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:site_name" content="The Tango Toolkit" />
    <meta name="twitter:title" content={`${title} | The Tango Toolkit`} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <meta name="theme-color" content="#f97316" />
    <title>{title} | The Tango Toolkit</title>
    {import.meta.env.PUBLIC_GA_ID && (
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`}></script>
      <script define:vars={{ gaId: import.meta.env.PUBLIC_GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="logo">
          <img src="/images/Logo.png" alt="Tango Toolkit" class="logo-img" width="40" height="40" />
          <span class="logo-text">The Tango Toolkit</span>
        </a>
        <nav class="nav">
          <a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>Home</a>
          <a href="/dj/starter-kit/" class={Astro.url.pathname.startsWith('/dj/starter-kit') ? 'active' : ''}>DJ Starter Kit</a>
          <a href="/dj/software/" class={Astro.url.pathname.startsWith('/dj/software') ? 'active' : ''}>DJ Tools</a>
          <a href="/dj/resources/" class={Astro.url.pathname.startsWith('/dj/resources') ? 'active' : ''}>Discographies</a>
          <a href="/dj/tanda-builder/" class={Astro.url.pathname.startsWith('/dj/tanda-builder') ? 'active' : ''}>Tanda Builder</a>
          <a href="/dj/articles/" class={Astro.url.pathname.startsWith('/dj/articles') || Astro.url.pathname.startsWith('/dj/history') ? 'active' : ''}>Resources</a>
        </nav>
        <button class="nav-toggle" aria-label="Toggle menu" type="button">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <strong>The Tango Toolkit</strong>
            <p>Resources for tango DJs.</p>
          </div>
          <div>
            <strong>Resources</strong>
            <a href="/dj/starter-kit/">DJ Starter Kit</a>
            <a href="/dj/software/">DJ Tools</a>
            <a href="/dj/resources/">Discographies</a>
            <a href="/dj/articles/">Resources</a>
          </div>
          <div>
            <strong>Help</strong>
            <a href="/dj/faq/">FAQ & Changelog</a>
            <a href="/dj/account/">My Licenses</a>
            <a href="/support/">Support</a>
          </div>
          <div>
            <strong>Legal</strong>
            <a href="/privacy/">Privacy Policy</a>
            <a href="/terms/">Terms of Service</a>
          </div>
          <div>
            <p>&copy; {new Date().getFullYear()} The Tango Toolkit</p>
          </div>
        </div>
      </div>
    </footer>

    {import.meta.env.PUBLIC_GA_ID && (
      <div class="cookie-banner" id="cookieBanner" style="display:none;">
        <div class="cookie-banner-inner">
          <p>This site uses cookies for analytics to help us improve. <a href="/privacy/">Learn more</a></p>
          <button class="btn btn-primary btn-sm" id="cookieAccept">Got it</button>
        </div>
      </div>
    )}

    <script>
      // Mobile nav toggle
      document.querySelector('.nav-toggle')?.addEventListener('click', () => {
        document.querySelector('.nav')?.classList.toggle('open');
      });

      // Close mobile nav when a link is clicked
      document.querySelectorAll('.nav a').forEach((link) => {
        link.addEventListener('click', () => {
          document.querySelector('.nav')?.classList.remove('open');
        });
      });

      // Cookie consent banner
      (function() {
        var banner = document.getElementById('cookieBanner');
        var acceptBtn = document.getElementById('cookieAccept');
        if (!banner || !acceptBtn) return;
        if (localStorage.getItem('cookie_consent')) return;
        banner.style.display = '';
        acceptBtn.addEventListener('click', function() {
          localStorage.setItem('cookie_consent', 'true');
          banner.style.display = 'none';
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: white;
    border-bottom: 1px solid var(--color-slate-200);
    box-shadow: var(--shadow-sm);
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-slate-900);
    font-weight: 400;
  }

  .logo:hover {
    color: var(--color-primary);
  }

  .logo-img {
    height: 2.5rem;
    width: auto;
  }

  .nav {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav a {
    font-weight: 500;
    color: var(--color-slate-600);
  }

  .nav a:hover,
  .nav a.active {
    color: var(--color-primary);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.75rem;
    border-radius: var(--radius-md);
    transition: background 0.15s;
  }

  .nav-toggle:hover {
    background: var(--color-slate-100);
  }

  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--color-slate-700);
    transition: background 0.15s;
  }

  .nav-toggle:hover span {
    background: var(--color-primary);
  }

  @media (max-width: 768px) {
    .nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: white;
      padding: 1.5rem;
      gap: 1rem;
      border-bottom: 1px solid var(--color-slate-200);
      display: none;
    }

    .nav.open {
      display: flex;
    }

    .nav-toggle {
      display: flex;
    }
  }

  .site-footer {
    margin-top: 4rem;
    padding: 3rem 0;
    background: var(--color-slate-800);
    color: var(--color-slate-300);
  }

  .site-footer a {
    color: var(--color-orange-300);
    display: block;
    margin-top: 0.5rem;
  }

  .site-footer a:hover {
    color: var(--color-orange-200);
  }

  .footer-grid {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  /* Cookie Consent Banner */
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: var(--color-slate-800);
    border-top: 1px solid var(--color-slate-700);
    box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.15);
  }

  .cookie-banner-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cookie-banner p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-slate-300);
  }

  .cookie-banner a {
    color: var(--color-orange-300);
    text-decoration: underline;
  }

  .cookie-banner a:hover {
    color: var(--color-orange-200);
  }

  .btn-sm {
    padding: 0.35rem 1rem;
    font-size: 0.85rem;
  }

</style>
