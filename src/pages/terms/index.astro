    margin: 2rem 0 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-slate-200);
  }

  h2:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  h3 {
    font-size: 1.1rem;
    margin: 1.25rem 0 0.5rem;
  }

  p, li {
    color: var(--color-slate-600);
