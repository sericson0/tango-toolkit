---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Tango DJ Resources" description="Courses, lessons, and materials for tango DJs. Learn music selection, tanda structure, and the art of DJing for milongas.">
  <section class="page-hero">
    <div class="container">
      <h1>Tango DJ Resources</h1>
      <p class="lead">Everything you need to start and grow as a tango DJ. From beginner courses to advanced techniques.</p>
    </div>
  </section>

  <section class="panels-section">
    <div class="container">
      <div class="panels-grid">
        <a href="/dj/starter-kit/" class="panel-card">
          <div class="panel-icon">🚀</div>
          <h2>Starter Kit</h2>
          <p>Everything you need to know and have to start tango DJing.</p>
          <span class="panel-link">Get Started →</span>
        </a>
        <a href="/dj/software/" class="panel-card">
          <div class="panel-icon">💻</div>
          <h2>Software</h2>
          <p>The best software and plugins available for tango DJs.</p>
          <span class="panel-link">Browse Software →</span>
        </a>
        <a href="/dj/resources/" class="panel-card">
          <div class="panel-icon">📚</div>
          <h2>Resources</h2>
          <p>Discographies, articles, and guides to deepen your knowledge.</p>
          <span class="panel-link">Explore Resources →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="ads-section">
    <div class="container">
      <h2 class="section-heading">From the Toolkit</h2>
      <div class="ads-grid">
        <a href="/dj/software/" class="ad-card">
          <div class="ad-badge">Free</div>
          <h3>TigerTango</h3>
          <p class="ad-tagline">An interface designed for Tango DJs</p>
          <p>A Virtual DJ skin built specifically for tango. Tanda-focused layout, warning lights, and streamlined controls.</p>
          <span class="ad-cta">Learn More →</span>
        </a>
        <a href="/dj/hisstory/" class="ad-card">
          <h3>Hisstory</h3>
          <p class="ad-tagline">Keep the music, ditch the noise</p>
          <p>Audio restoration for tango DJs. Remove hiss and noise from vintage recordings while preserving the music.</p>
          <span class="ad-cta">Learn More &rarr;</span>
        </a>
        <a href="/dj/software/" class="ad-card">
          <h3>TigerTag</h3>
          <p class="ad-tagline">Tag your tango tunes</p>
          <p>Batch-tag your tango music library with orchestra, singer, year, genre, and more.</p>
          <span class="ad-cta">Coming Soon</span>
        </a>
        <a href="/dj/software/" class="ad-card">
          <h3>TigerTanda</h3>
          <p class="ad-tagline">Find the tracks for the perfect tanda</p>
          <p>Intelligent tanda builder that suggests complementary tracks based on orchestra, era, and style.</p>
          <span class="ad-cta">Coming Soon</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 3rem 0;
    background: linear-gradient(135deg, var(--color-orange-50) 0%, white 100%);
    border-bottom: 1px solid var(--color-orange-100);
  }

  .page-hero h1 {
    margin: 0 0 0.5rem;
  }

  .lead {
    font-size: 1.2rem;
    color: var(--color-slate-600);
    margin: 0;
    max-width: 50ch;
  }

  .panels-section {
    padding: 3rem 0;
  }

  .panels-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .panels-grid {
      grid-template-columns: 1fr;
    }
  }

  .panel-card {
    background: white;
    border: 2px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .panel-card:hover {
    border-color: var(--color-orange-400);
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .panel-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .panel-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.35rem;
  }

  .panel-card p {
    margin: 0 0 1rem;
    color: var(--color-slate-600);
    font-size: 0.95rem;
  }

  .panel-link {
    font-weight: 600;
    color: var(--color-primary);
    font-size: 0.95rem;
  }

  /* Advertisements */
  .ads-section {
    padding: 3rem 0 4rem;
    background: var(--color-slate-50);
    border-top: 1px solid var(--color-slate-200);
  }

  .section-heading {
    text-align: center;
    margin: 0 0 2rem;
  }

  .ads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .ad-card {
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
    position: relative;
  }

  .ad-card:hover {
    border-color: var(--color-orange-400);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .ad-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    background: var(--color-orange-100);
    color: var(--color-orange-800);
  }

  .ad-card h3 {
    margin: 0 0 0.25rem;
    font-size: 1.15rem;
  }

  .ad-tagline {
    font-style: italic;
    color: var(--color-orange-600);
    font-size: 0.9rem;
    margin: 0 0 0.75rem;
  }

  .ad-card p {
    margin: 0 0 1rem;
    color: var(--color-slate-600);
    font-size: 0.9rem;
  }

  .ad-cta {
    font-weight: 600;
    color: var(--color-primary);
    font-size: 0.9rem;
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
</style>
