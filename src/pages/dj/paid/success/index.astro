---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
---

<BaseLayout title="Purchase Complete" description="Thank you for your purchase from Tango Toolkit.">
  <section class="success-page">
    <div class="container narrow-sm">
      <div class="success-card">
        <div class="checkmark">&#10003;</div>
        <h1>Thank you for your purchase!</h1>
        <p id="confirmation-message">
          Your license key is on its way. Check your email inbox (and spam folder) for your activation key.
        </p>

        <div id="license-key-display" class="license-key-box" hidden>
          <label>Your license key</label>
          <div class="license-key-row">
            <code id="license-key-value">&nbsp;</code>
            <button type="button" id="copy-btn" class="copy-btn">Copy</button>
          </div>
        </div>

        <div id="instructions" class="instructions">
          <h3>How to activate</h3>
          <ol id="activation-steps">
            <li>Open the app (standalone or plugin)</li>
            <li>Click <strong>"Enter Key"</strong></li>
            <li>Paste the key above and click <strong>"Activate"</strong></li>
          </ol>
        </div>

        <div class="success-links">
          <a href="/dj/software/" class="btn btn-primary">&larr; Back to Products</a>
          <a href="/" class="btn btn-secondary">Home</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const PRODUCT_INFO: Record<string, { name: string; steps: string[] }> = {
    hisstory: {
      name: 'Hisstory',
      steps: [
        'Open Hisstory (standalone or VST3 plugin)',
        'Click <strong>"Enter Key"</strong>',
        'Paste the key above and click <strong>"Activate"</strong>',
      ],
    },
    tigertag: {
      name: 'TigerTag',
      steps: [
        'Open TigerTag',
        'Click <strong>"Enter Key"</strong>',
        'Paste the key above and click <strong>"Activate"</strong>',
      ],
    },
  };

  const params = new URLSearchParams(window.location.search);
  const sessionId = params.get('session_id');
  const messageEl = document.getElementById('confirmation-message');
  const keyBox = document.getElementById('license-key-display');
  const keyValueEl = document.getElementById('license-key-value');
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement | null;
  const stepsEl = document.getElementById('activation-steps');

  if (sessionId && messageEl && keyBox && keyValueEl && copyBtn) {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);

    messageEl.textContent = 'Loading your license key\u2026';

    fetch(`/api/get-license-info?session_id=${encodeURIComponent(sessionId)}`, {
      signal: controller.signal,
    })
      .then(async (res) => {
        if (!res.ok) throw new Error(`Status ${res.status}`);
        return res.json() as Promise<{ email: string | null; licenseKey: string; productId: string }>;
      })
      .then(({ email, licenseKey, productId }) => {
        keyValueEl.textContent = licenseKey;
        keyBox.hidden = false;

        // Update activation steps for the purchased product
        const info = productId ? PRODUCT_INFO[productId] : undefined;
        if (info && stepsEl) {
          stepsEl.innerHTML = info.steps.map((s) => `<li>${s}</li>`).join('');
        }

        const productName = info?.name || 'your product';
        const emailText = email
          ? ` A copy was also sent to <strong>${email}</strong> — check your inbox (and spam folder) if you don't see it.`
          : " A copy was also sent to your email — check your inbox (and spam folder) if you don't see it.";
        messageEl.innerHTML =
          `Here is your <strong>${productName}</strong> activation key.` + emailText;
      })
      .catch((err) => {
        if (err.name === 'AbortError') {
          messageEl.innerHTML = 'Taking longer than expected. Your license key was sent to your email — check your inbox (and spam folder). You can also recover it anytime from <a href="/dj/account/">My Licenses</a>.';
        } else {
          console.error('Failed to load license info:', err);
          messageEl.innerHTML = 'Your license key was sent to your email — check your inbox (and spam folder). You can also recover it anytime from <a href="/dj/account/">My Licenses</a>.';
        }
      })
      .finally(() => clearTimeout(timeoutId));

    copyBtn.addEventListener('click', async () => {
      const key = keyValueEl.textContent?.trim() ?? '';
      if (!key) return;
      try {
        await navigator.clipboard.writeText(key);
        const original = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => {
          copyBtn.textContent = original;
        }, 2500);
      } catch {
        alert('Copy failed. Please select and copy the key manually.');
      }
    });
  }
</script>

<style>
  .success-page {
    padding: 5rem 0;
    min-height: 50vh;
    display: flex;
    align-items: center;
  }

  .success-card { text-align: center; }

  .checkmark {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: var(--color-orange-100);
    color: var(--color-orange-600);
    font-size: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .success-card h1 { margin: 0 0 0.75rem; }

  .success-card > p {
    font-size: 1.1rem;
    color: var(--color-slate-600);
    margin: 0 0 2rem;
    max-width: 48ch;
    margin-left: auto;
    margin-right: auto;
  }

  .license-key-box {
    margin-bottom: 2rem;
  }

  .instructions {
    text-align: left;
    background: var(--color-slate-50);
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .instructions h3 {
    margin: 0 0 0.75rem;
    font-size: 1rem;
  }

  .instructions ol {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--color-slate-600);
    line-height: 1.8;
  }

  .success-links { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
</style>
