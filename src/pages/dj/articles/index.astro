---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
---

<BaseLayout title="Resources & Links — Tango DJ" description="Useful resources for tango DJs, dancers, and music lovers." ogImage="/images/Stages%20of%20Music.png">
  <PageHero title="Resources & Links" lead="Useful resources for tango DJs, dancers, and music lovers." />

  <section class="articles-section">
    <div class="container">
      <h2 class="section-heading">Articles</h2>
      <div class="articles-grid">

        <a href="/dj/history-of-tango-music/" class="article-card">
          <picture>
            <source srcset="/articles/history-of-tango-music/Orquestras-and-Recordings-per-year-800x480.webp 800w, /articles/history-of-tango-music/Orquestras-and-Recordings-per-year-1200x720.webp 1200w, /articles/history-of-tango-music/Orquestras-and-Recordings-per-year-2048x1229.webp 2048w" sizes="(max-width: 768px) 100vw, 600px" type="image/webp" />
            <img src="/articles/history-of-tango-music/Orquestras-and-Recordings-per-year-1024x614.png" alt="Tango orchestras and recordings by year" class="article-card-img" width="1024" height="614" loading="lazy" decoding="async" />
          </picture>
          <div class="article-card-body">
            <h3>The History of Tango Music</h3>
            <p>How many tango recordings are there? A deep dive into the history of tango music, the recording industry, and Argentina &mdash; from the first tango recording in 1905 to the modern restoration movement.</p>
            <span class="card-cta">Read Article &rarr;</span>
          </div>
        </a>

      </div>

      <h2 class="section-heading" style="margin-top: 2.5rem;">External Resources</h2>
      <div class="links-grid">
        <a href="https://www.notasdeoro.com/" target="_blank" rel="noopener noreferrer" class="link-card">
          <strong>Notas de Oro</strong>
          <p class="link-card-tagline">Learn the tales behind the tangos.</p>
          <p>Notas de Oro explores the history and music of the Golden Age of tango orchestras. Learn to recognize the orchestras, understand the meaning behind the lyrics, and discover the history and the dramatic stories behind the tangos we love to listen and dance to. One song per week, one orchestra per month.</p>
          <span class="card-cta">Visit Notas de Oro &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="links-section">
    <div class="container">
      <h2 class="section-heading">Links</h2>
      <div class="links-grid">
        <a href="/dj/starter-kit/" class="link-card">
          <strong>DJ Starter Kit</strong>
          <p>Everything you need to know to start tango DJing.</p>
        </a>
        <a href="/dj/software/" class="link-card">
          <strong>DJ Tools</strong>
          <p>Software and plugins built for tango DJs.</p>
        </a>
        <a href="/dj/resources/" class="link-card">
          <strong>Discographies</strong>
          <p>Nearly 15,000 tangos from more than 40 artists.</p>
        </a>
        <a href="/dj/faq/" class="link-card">
          <strong>FAQ & Changelog</strong>
          <p>Common questions and recent software updates.</p>
        </a>
        <a href="/dj/account/" class="link-card">
          <strong>My Licenses</strong>
          <p>Recover your license keys by email.</p>
        </a>
        <a href="/privacy/" class="link-card">
          <strong>Privacy Policy</strong>
          <p>How we collect, use, and protect your data.</p>
        </a>
        <a href="/terms/" class="link-card">
          <strong>Terms of Service</strong>
          <p>Terms for using our website and software.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .articles-section {
    padding: 3rem 0;
  }

  .links-section {
    padding: 0 0 3rem;
  }

  .section-heading {
    margin: 0 0 1.25rem;
    font-size: 1.5rem;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .link-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    transition: all 0.2s;
  }

  .link-card:hover {
    border-color: var(--color-orange-400);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .link-card strong {
    font-size: 1.05rem;
    color: var(--color-slate-800);
  }

  .link-card p {
    margin: 0.35rem 0 0;
    font-size: 0.9rem;
    color: var(--color-slate-500);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    max-width: 500px;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.2s;
  }

  .article-card:hover {
    border-color: var(--color-orange-400);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .article-card-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .article-card-body {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .article-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }

  .article-card p {
    margin: 0 0 1rem;
    color: var(--color-slate-600);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .link-card-tagline {
    font-style: italic;
    color: var(--color-orange-600) !important;
    font-weight: 500;
    margin-bottom: 0.5rem !important;
  }

  .card-cta {
    font-weight: 600;
    color: var(--color-primary);
    font-size: 0.95rem;
  }
</style>
