---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { products } from '../../../data/products';
---

<BaseLayout title="DJ Tools" description="Software and plugins built for tango DJs. Download free tools and pro-level utilities for music management, audio restoration, and tanda building.">
  <section class="page-hero">
    <div class="container">
      <a href="/" class="back-link">&larr; Back to Home</a>
      <h1>DJ Tools</h1>
      <p class="lead">Software and plugins built for tango DJs.</p>
    </div>
  </section>

  <section class="tools-section">
    <div class="container">
      <div class="tools-list">
        {products.map((product) => (
          <article class="tool-row">
            <div class="tool-info">
              <h3>{product.name}</h3>
              <p class="tool-tagline">{product.tagline}</p>
              <p class="tool-desc">{product.description}</p>
            </div>
            <div class="tool-side">
              {product.image && (
                <div class="tool-image">
                  <img src={product.image} alt={product.name} />
                </div>
              )}
              <div class="tool-actions">
                <a href={product.downloadLink} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                  {product.trial ? 'Download Trial' : 'Download Free'}
                </a>
                {product.trial && product.paymentLink && (
                  <a href={product.paymentLink} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
                    Purchase Key — {product.price}
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 3rem 0;
    background: linear-gradient(135deg, var(--color-orange-50) 0%, white 100%);
    border-bottom: 1px solid var(--color-orange-100);
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: var(--color-slate-600);
  }

  .back-link:hover { color: var(--color-primary); }
  .page-hero h1 { margin: 0 0 0.5rem; }

  .lead {
    font-size: 1.2rem;
    color: var(--color-slate-600);
    margin: 0;
  }

  .tools-section {
    padding: 3rem 0 4rem;
  }

  .tools-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .tool-row {
    display: flex;
    gap: 2rem;
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: all 0.2s;
  }

  .tool-row:hover {
    border-color: var(--color-orange-400);
    box-shadow: var(--shadow-md);
  }

  .tool-info {
    flex: 2;
    min-width: 0;
  }

  .tool-info h3 {
    margin: 0 0 0.25rem;
    font-size: 1.35rem;
  }

  .tool-tagline {
    font-style: italic;
    color: var(--color-orange-600);
    font-size: 0.9rem;
    margin: 0 0 0.75rem;
  }

  .tool-desc {
    margin: 0;
    color: var(--color-slate-600);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .tool-side {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    justify-content: center;
  }

  .tool-image {
    width: 100%;
    max-width: 240px;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-slate-100);
  }

  .tool-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .tool-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    max-width: 240px;
  }

  .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: 0.9rem;
    text-align: center;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    color: white;
  }

  .btn-secondary {
    background: var(--color-slate-100);
    color: var(--color-slate-700);
  }

  .btn-secondary:hover {
    background: var(--color-slate-200);
    color: var(--color-slate-800);
  }

  @media (max-width: 768px) {
    .tool-row {
      flex-direction: column;
    }

    .tool-side {
      align-items: flex-start;
    }

    .tool-image,
    .tool-actions {
      max-width: 100%;
    }
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
</style>
