---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import { getProductsMap } from '../../../data/products';

const { tigertango, hisstory, tigertag, tigertanda } = getProductsMap();

const WIN_SVG = '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M0 3.5l9.75-1.33v9.41H0V3.5zm0 17l9.75 1.33v-9.32H0v7.99zM10.83 21.98L24 24V12.68H10.83v9.3zm0-19.96v9.4H24V0L10.83 2.02z"/></svg>';
const APPLE_SVG = '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>';
---

<BaseLayout title="DJ Tools" description="Software and plugins built for tango DJs. Download free tools and pro-level utilities for music management, audio restoration, and tanda building.">
  <PageHero title="DJ Tools" lead="Software and plugins built for tango DJs." />
    <div class="email-opt-in">
      Sign up here to stay up to date on the latest updates, features, and releases
      <form class="email-gate-form" data-product-id="tigertango" data-optional="true">
        <input type="email" placeholder="your@email.com (optional)" />
        <button type="submit">Subscribe</button>
      </form>
    </div>
  <!-- ===== Tool Cards Nav ===== -->
  <section class="tool-cards-nav">
    <div class="container">
      <div class="tool-cards-grid">
        <a href="#tigertango" class="tool-card-nav">
          {tigertango?.image && <img src={tigertango.image} alt="TigerTango" class="tool-card-icon" width="48" height="48" />}
          <div>
            <strong>TigerTango</strong>
            <span class="tool-card-tagline">VirtualDJ interface for tango</span>
            <span class="tool-card-price">Free</span>
          </div>
        </a>
        <a href="#hisstory" class="tool-card-nav">
          {hisstory?.image && <img src={hisstory.image} alt="Hisstory" class="tool-card-icon" width="48" height="48" />}
          <div>
            <strong>Hisstory</strong>
            <span class="tool-card-tagline">Audio de-hissing plugin</span>
            <span class="tool-card-price">$40 (Try for Free)</span>
          </div>
        </a>
        <a href="#tigertag" class="tool-card-nav">
          {tigertag?.image && <img src={tigertag.image} alt="TigerTag" class="tool-card-icon" width="48" height="48" />}
          <div>
            <strong>TigerTag</strong>
            <span class="tool-card-tagline">Batch metadata tagger</span>
            <span class="tool-card-price">{tigertag?.price} (Try for Free)</span>
          </div>
        </a>
        <a href="#tigertanda" class="tool-card-nav">
          {tigertanda?.image && <img src={tigertanda.image} alt="TigerTanda" class="tool-card-icon" width="48" height="48" />}
          <div>
            <strong>TigerTanda</strong>
            <span class="tool-card-tagline">Tanda builder</span>
            <span class="tool-card-price">Free</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TigerTango                                                    -->
  <!-- ============================================================ -->
  <section id="tigertango" class="tool-section">
    <div class="container">
      <div class="tool-header">
        {tigertango?.image && (
          <div class="tool-logo tool-logo--wide">
            <img src={tigertango.image} alt="TigerTango" width="135" height="90" />
          </div>
        )}
        <div>
          <h2>TigerTango</h2>
          <p class="tool-tagline">A VirtualDJ Interface Designed for Tango DJs</p>
          <span class="price-badge">Free</span>
        </div>
      </div>

      <p class="tool-desc-full">Nothing kills the magic of the milonga like technical issues. Whether you are just starting out as a tango DJ, or are traveling to DJ the biggest festivals, you deserve software that enables your creativity instead of hindering the flow you are striving so hard to create. TigerTango is a customized Virtual DJ skin specifically designed for the needs of tango DJs.</p>

      <div class="features-grid">
        <div class="feature-item">Power and reliability of Virtual DJ</div>
        <div class="feature-item">Clean interface configured for tango DJing</div>
        <div class="feature-item">Added safety features so you can focus on the dancers</div>
        <div class="feature-item">Built-in semiparametric equalizer</div>
        <div class="feature-item">VST3 and Video display integrations</div>
        <div class="feature-item">Song fade-out buttons (great for cortinas)</div>
      </div>

      <div class="testimonials">
        <blockquote>
          <p>&ldquo;The TigerTango VirtualDJ skin interface is perfect for Tango DJs. As a Traktor user for the last 10 years I never stopped looking for a more practical alternative, until now.&rdquo;</p>
          <cite>&mdash; &Eacute;ric Heleno, Sound Systems Engineer &amp; Tango DJ</cite>
        </blockquote>
        <blockquote>
          <p>&ldquo;Until now, software for Tango DJing meant compromise: too little, or way too much. TigerTango fixes this. Designed and tuned for Tango DJs, its interface and unique features finally fit our craft.&rdquo;</p>
          <cite>&mdash; DJ Ragnar (Germany)</cite>
        </blockquote>
        <blockquote>
          <p>&ldquo;It is totally awesome, making tango DJ-ing wonderfully streamlined on the technical side. VDJ with TigerTango blows all other options out of water. Loving it!!!&rdquo;</p>
          <cite>&mdash; TDJ Michael Plaks (Houston, Texas)</cite>
        </blockquote>
      </div>

      <!-- Download Virtual DJ -->
      <p>
      Tiger Tango is built on Virtual DJ, so you want to download that first.
      You can get it from their website  <a href="https://virtualdj.com/">here</a>.
    
      </p>
      <h3 class="section-label">Download Virtual DJ 2025</h3>
      <div class="callout callout-warning">
        <strong>Use the 2025 version of Virtual DJ.</strong>
        <p>The 2026 release added an audio watermark to the free version. For those who would like to try out the full free version,
        we have added a link to the 2025 version below. (Follow steps to disable automatic updates). </p>
      </div>

      <div class="download-buttons">
        <a href="https://drive.google.com/uc?export=download&id=1-dSX1T8CV3mvqYst62TgHBXYHTrItlkQ" target="_blank" rel="noopener" class="download-btn-large">
          <span class="dl-icon" set:html={WIN_SVG}></span>
          <div>
            <strong>Download for Windows</strong>
            <span>Virtual DJ 2025 (.msi, 464 MB)</span>
          </div>
        </a>
        <a href="https://drive.google.com/uc?export=download&id=1zHCTXZbJLP-IyKM0wCetCgjwc3lOzm97" target="_blank" rel="noopener" class="download-btn-large">
          <span class="dl-icon" set:html={APPLE_SVG}></span>
          <div>
            <strong>Download for Mac</strong>
            <span>Virtual DJ 2025 (.pkg, 910 MB)</span>
          </div>
        </a>
      </div>

      <!-- Download TigerTango -->
      <h3 class="section-label">Download TigerTango</h3>
      <p class="install-note">You can install TigerTango directly in Virtual DJ: <strong>Settings &rarr; Extensions &rarr; Search "TigerTango"</strong>.
        You can also download the latest version with the link below.</p>
      <p class="install-link">
        &#128214; <a href="https://github.com/sericson0/TigerTango/blob/main/docs/sections/Installation.md" target="_blank" rel="noopener noreferrer">Installation and User guide</a>
      </p>
      <div class="download-buttons">
        <a href="https://github.com/sericson0/TigerTango/releases/latest/download/TigerTango.zip" class="download-btn-large">
          <span class="dl-icon">&#127926;</span>
          <div>
            <strong>TigerTango</strong>
            <span>DJ interface skin (.zip)</span>
          </div>
        </a>
        <a href="https://github.com/sericson0/TigerTango/releases/latest/download/TigerTangoVideo.zip" class="download-btn-large">
          <span class="dl-icon">&#127916;</span>
          <div>
            <strong>TigerTango Video</strong>
            <span>Video display skin (.zip)</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- Hisstory                                                      -->
  <!-- ============================================================ -->
  <section id="hisstory" class="tool-section alt-bg">
    <div class="container">
      <div class="tool-header">
        {hisstory?.image && (
          <div class="tool-logo tool-logo--wide">
            <img src={hisstory.image} alt="Hisstory" width="135" height="90" />
          </div>
        )}
        <div>
          <h2>Hisstory</h2>
          <p class="tool-tagline">Keep the music, ditch the noise</p>
          <span class="price-badge">$40 (Try For Free)</span>
          <span class="license-note">One-time purchase, lifetime access</span>
        </div>
      </div>

      <p class="tool-desc-full">A real-time spectral gating plugin designed for removing hiss while keeping high-frequency music and transients intact and sounding as natural as possible. Works on Windows and macOS.</p>

      <div class="features-grid">
        <div class="feature-item">VST3 and AU plugins</div>
        <div class="feature-item">Real-time de-hissing with spectral gating</div>
        <div class="feature-item">Adaptive noise tracking that learns the noise floor</div>
        <div class="feature-item">Protects music save sound quality</div>
        <div class="feature-item">Analyzer + spectrogram visualizations</div>
        <div class="feature-item">Advanced features for precice adjustment</div>
      </div>

      <!-- Download -->
      <h3 class="section-label">Download</h3>
      <p class="section-note">Hisstory is free to try for 2 days with full access &mdash; no credit card required. To keep using it after the trial, click <strong>Purchase License</strong> below and you&rsquo;ll receive an activation key by email to paste into the app.</p>
      {hisstory?.stripePriceId && (
        <div class="purchase-row">
          <button type="button" class="download-btn-large purchase-btn checkout-btn" data-product-id="hisstory">
            <span class="dl-icon">&#128179;</span>
            <div>
              <strong>Purchase License &mdash; $40</strong>
              <span>One-time purchase, lifetime access</span>
            </div>
          </button>
        </div>
      )}
      <p class="install-link">
        &#128214; <a href="/documentation/Hisstory User Guide.pdf" target="_blank" rel="noopener noreferrer">User Guide (PDF)</a>
      </p>
      <div class="download-buttons">
        <a href="https://github.com/sericson0/hisstory-releases/releases/latest/download/Hisstory-Windows-Installer.exe" class="download-btn-large">
          <span class="dl-icon" set:html={WIN_SVG}></span>
          <div>
            <strong>Download for Windows</strong>
            <span>Hisstory installer (.exe)</span>
          </div>
        </a>
        <a href="https://github.com/sericson0/hisstory-releases/releases/latest/download/Hisstory.vst3" class="download-btn-large">
          <span class="dl-icon" set:html={WIN_SVG}></span>
          <div>
            <strong>Windows VST3 Plugin Only</strong>
            <span>Hisstory.vst3 &mdash; manual install</span>
          </div>
        </a>
        <a href="https://github.com/sericson0/hisstory-releases/releases/latest/download/Hisstory-macOS.dmg" class="download-btn-large">
          <span class="dl-icon" set:html={APPLE_SVG}></span>
          <div>
            <strong>Download for macOS</strong>
            <span>Hisstory installer (.dmg)</span>
          </div>
        </a>
      </div>

      <!-- Install -->
      <h3 class="section-label">Install VST3 Plugin Manually</h3>
      <p class="callout callout-config callout-inline"><strong>Windows note:</strong> The installer may trigger a SmartScreen warning. Click <strong>More info</strong> &rarr; <strong>Run anyway</strong> to proceed, or download the VST3 plugin and install manually below.</p>
      <div class="guide-content">
        <h4>Windows</h4>
        <p>Copy <code>Hisstory.vst3</code> to <code>C:\Program Files\Common Files\VST3\Hisstory.vst3</code>, then rescan plugins in your DAW.</p>

        <h4>macOS</h4>
        <p>Double-click the downloaded <code>.dmg</code> file to mount it &mdash; a window will open showing <code>Hisstory.vst3</code>. Drag it into <code>/Library/Audio/Plug-Ins/VST3/</code> (system-wide) or <code>~/Library/Audio/Plug-Ins/VST3/</code> (current user only), then eject the disk image and restart or rescan plugins in your DAW.</p>
      </div>

      <p class="contact-note">Questions or feedback? Reach out at <a href="mailto:tangotoolkit@gmail.com">tangotoolkit@gmail.com</a></p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TigerTag                                                      -->
  <!-- ============================================================ -->
  <section id="tigertag" class="tool-section">
    <div class="container">
      <div class="tool-header">
        {tigertag?.image && (
          <div class="tool-logo">
            <img src={tigertag.image} alt="TigerTag" width="90" height="90" />
          </div>
        )}
        <div>
          <h2>TigerTag</h2>
          <p class="tool-tagline">Tag your tango tunes</p>
          <span class="price-badge">{tigertag?.price} (Try For Free)</span>
          <span class="license-note">One-time purchase, lifetime access</span>
        </div>
      </div>

      <p class="tool-desc-full">Batch-tag your tango music library with orchestra, singer, year, genre, and more. Save hours of manual metadata work.</p>

      <div class="features-grid">
        <div class="feature-item">Metadata on more than 15,000 songs</div>
        <div class="feature-item">Configurable to your preferences</div>
        <div class="feature-item">Saves you hours of work</div>
        <div class="feature-item">Add correct title, artist, orchestra, singer, year, genre, composer, and more</div>
        <div class="feature-item">Option to make filenames clean as well</div>
        <div class="feature-item">Try for free!</div>
      </div>
      <p class="callout callout-config callout-inline"><strong>Windows note:</strong> The installer may trigger a SmartScreen warning. Click <strong>More info</strong> &rarr; <strong>Run anyway</strong> to proceed.</p>
      <div class="purchase-row">
        <button type="button" class="download-btn-large purchase-btn checkout-btn" data-product-id="tigertag">
          <span class="dl-icon">&#128179;</span>
          <div>
            <strong>Purchase Key &mdash; {tigertag?.price}</strong>
            <span>One-time purchase, lifetime access</span>
          </div>
        </button>
      </div>
      <p class="install-link">
        &#128214; <a href="/documentation/TigerTag User Guide.pdf" target="_blank" rel="noopener noreferrer">User Guide (PDF)</a>
      </p>
      <div class="download-buttons">
        <a href="https://github.com/sericson0/tigertag-releases/releases/latest/download/TigerTagSetup.exe" class="download-btn-large">
          <span class="dl-icon" set:html={WIN_SVG}></span>
          <div>
            <strong>Download for Windows</strong>
            <span>TigerTag installer (.exe)</span>
          </div>
        </a>
        <a href="https://github.com/sericson0/tigertag-releases/releases/latest/download/TigerTag-Windows-x64.zip" class="download-btn-large">
          <span class="dl-icon" set:html={WIN_SVG}></span>
          <div>
            <strong>Windows Portable</strong>
            <span>TigerTag (.zip)</span>
          </div>
        </a>
        <a href="https://github.com/sericson0/tigertag-releases/releases/latest/download/TigerTag-macOS.dmg" class="download-btn-large">
          <span class="dl-icon" set:html={APPLE_SVG}></span>
          <div>
            <strong>Download for macOS</strong>
            <span>TigerTag (.dmg)</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TigerTanda                                                    -->
  <!-- ============================================================ -->
  <section id="tigertanda" class="tool-section alt-bg">
    <div class="container">
      <div class="tool-header">
        {tigertanda?.image && (
          <div class="tool-logo tool-logo--wide">
            <img src={tigertanda.image} alt="TigerTanda" width="135" height="90" />
          </div>
        )}
        <div>
          <h2>TigerTanda</h2>
          <p class="tool-tagline">Find the tracks for the perfect tanda</p>
          <span class="price-badge">Free</span>
        </div>
      </div>

      <p class="tool-desc-full">Virtual DJ plugin that helps you quickly find the perfect matches to build out a tanda. You can also try our
        <a href="/dj/tanda-builder/">online tool</a> that utilizes the same logic and data to help find songs that work well in a tanda.
      </p>

      <div class="features-grid">
        <div class="feature-item">Integrates into Virtual DJ</div>
        <div class="feature-item">Shows which songs work well with selected song.</div>
        <div class="feature-item">Filter by artist, singer, genre, grouping, year range and more</div>
        <div class="feature-item">Helps you find the right song in your library to quickly build killer tandas</div>
        <div class="feature-item">FREE!!!</div>
      </div>

      <p class="install-link">
        &#128214; <a href="https://github.com/sericson0/tigertanda-vdj/blob/main/README.md" target="_blank" rel="noopener noreferrer">User guide</a>
        &nbsp;&middot;&nbsp;
        <a href="https://raw.githubusercontent.com/sericson0/tigertanda-vdj/main/README.pdf" target="_blank" rel="noopener noreferrer" download>Download PDF</a>
        &nbsp;&middot;&nbsp;
        <a href="/documentation/TigerTanda Quickstart Guide.pdf" target="_blank" rel="noopener noreferrer">User Guide (PDF)</a>
      </p>
      <div class="download-buttons">
        <a href="https://github.com/sericson0/tigertanda-vdj/releases/latest/download/TigerTanda-Windows-Installer.exe" class="download-btn-large tigertanda-dl">
          <span class="dl-icon" set:html={WIN_SVG}></span>
          <div>
            <strong>Download for Windows</strong>
            <span>TigerTanda installer (.exe)</span>
          </div>
        </a>
        <a href="https://github.com/sericson0/tigertanda-vdj/releases/latest/download/TigerTanda-Windows.zip" class="download-btn-large tigertanda-dl">
          <span class="dl-icon" set:html={WIN_SVG}></span>
          <div>
            <strong>Windows Portable</strong>
            <span>TigerTanda (.zip)</span>
          </div>
        </a>
        <a href="https://github.com/sericson0/tigertanda-vdj/releases/latest/download/TigerTanda-macOS.zip" class="download-btn-large tigertanda-dl">
          <span class="dl-icon" set:html={APPLE_SVG}></span>
          <div>
            <strong>Download for macOS</strong>
            <span>TigerTanda (.zip)</span>
          </div>
        </a>
      </div>

      <h3 class="section-label">Installation Instructions</h3>
      <details class="guide-expander">
        <summary>Windows (Installer)</summary>
        <div class="guide-content">
          <ol>
            <li>Download <code>TigerTanda-Windows-Installer.exe</code>.</li>
            <li>Run the installer &mdash; it defaults to <code>Documents\VirtualDJ\Plugins64\SoundEffect\TigerTanda\</code>.</li>
            <li>Restart VirtualDJ.</li>
            <li>Click one of the Master Effects slots &rarr; click <strong>More...</strong> &rarr; select <strong>TigerTanda</strong> &rarr; use the <strong>&gt;</strong> button to add.</li>
            <li>You can now add TigerTanda to an effects slot and open it.</li>
          </ol>
        </div>
      </details>
      <details class="guide-expander">
        <summary>Windows (Manual)</summary>
        <div class="guide-content">
          <ol>
            <li>Download <code>TigerTanda-Windows.zip</code>.</li>
            <li>Extract the zip &mdash; you&rsquo;ll get <code>TigerTanda.dll</code> and <code>metadata.csv</code>.</li>
            <li>Copy both files to <code>Documents\VirtualDJ\Plugins64\SoundEffect\TigerTanda\</code>.</li>
            <li>Restart VirtualDJ.</li>
            <li>Click one of the Master Effects slots &rarr; click <strong>More...</strong> &rarr; select <strong>TigerTanda</strong> &rarr; use the <strong>&gt;</strong> button to add.</li>
            <li>You can now add TigerTanda to an effects slot and open it.</li>
          </ol>
        </div>
      </details>
      <details class="guide-expander">
        <summary>macOS</summary>
        <div class="guide-content">
          <ol>
            <li>Download <code>TigerTanda-macOS.zip</code>.</li>
            <li>Extract the zip &mdash; you&rsquo;ll get <code>TigerTanda.bundle</code> and <code>metadata.csv</code>.</li>
            <li>Copy both to your VirtualDJ plugins folder: <code>~/Library/Application Support/VirtualDJ/Plugins64/SoundEffect/</code>.</li>
            <li>Restart VirtualDJ.</li>
            <li>The TigerTanda window appears automatically when VirtualDJ is in the foreground.</li>
          </ol>
        </div>
      </details>
    </div>
  </section>

  <div id="tigertanda-modal" class="tt-modal" hidden>
    <div class="tt-modal-backdrop" data-close></div>
    <div class="tt-modal-content" role="dialog" aria-modal="true" aria-labelledby="tt-modal-title">
      <button class="tt-modal-close" aria-label="Close" data-close>&times;</button>
      <h3 id="tt-modal-title">Before you download</h3>
      <p>Want updates on new features? Drop your email &mdash; no spam, unsubscribe anytime.</p>
      <form id="tt-modal-form">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit" class="tt-modal-primary">Subscribe &amp; Download</button>
      </form>
      <button type="button" class="tt-modal-skip" data-skip>No thanks, just take me to the plugin</button>
      <p class="tt-modal-error" hidden></p>
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.checkout-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const button = e.currentTarget as HTMLButtonElement;
      const productId = button.dataset.productId;

      button.disabled = true;
      button.style.cursor = 'wait';
      const strongEl = button.querySelector('strong');
      const originalText = strongEl?.textContent || '';
      if (strongEl) strongEl.innerHTML = '<span class="spinner"></span> Loading\u2026';

      // Clear any previous error
      const prevError = button.parentElement?.querySelector('.checkout-error');
      if (prevError) prevError.remove();

      try {
        const response = await fetch('/api/create-checkout-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId }),
        });

        if (!response.ok) {
          throw new Error('Failed to create checkout session');
        }

        const { url } = await response.json();
        window.location.href = url;
      } catch (err) {
        console.error('Checkout error:', err);
        button.disabled = false;
        button.style.cursor = '';
        if (strongEl) strongEl.textContent = originalText;

        const errorDiv = document.createElement('div');
        errorDiv.className = 'checkout-error';
        errorDiv.textContent = 'Something went wrong. Please try again.';
        button.parentElement?.insertBefore(errorDiv, button.nextSibling);
      }
    });
  });

  // Email capture forms
  document.querySelectorAll('.email-gate-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.currentTarget as HTMLFormElement;
      const input = formEl.querySelector('input[type="email"]') as HTMLInputElement;
      const submitBtn = formEl.querySelector('button') as HTMLButtonElement;
      const productId = formEl.dataset.productId;
      const isOptional = formEl.dataset.optional === 'true';

      const email = input.value.trim();
      if (!email) {
        if (isOptional) return;
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending\u2026';

      // Clear previous errors
      const prevError = formEl.parentElement?.querySelector('.email-gate-error');
      if (prevError) prevError.remove();

      try {
        const response = await fetch('/api/capture-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, productId }),
        });

        if (!response.ok) throw new Error('Failed');

        if (isOptional) {
          // Replace the form with a success message
          formEl.innerHTML = '<span class="email-gate-success">Subscribed! Check your inbox for updates.</span>';
        } else {
          // Show download buttons and hide the email gate
          const gate = formEl.closest('.email-gate') as HTMLElement;
          const downloads = gate?.nextElementSibling as HTMLElement;
          if (gate) gate.innerHTML = '<p class="email-gate-success">Thanks! Your download links are ready below.</p>';
          if (downloads) downloads.style.display = '';
        }
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = isOptional ? 'Subscribe' : 'Get Download Link';

        const errorDiv = document.createElement('div');
        errorDiv.className = 'email-gate-error';
        errorDiv.textContent = 'Something went wrong. Please try again.';
        formEl.parentElement?.appendChild(errorDiv);
      }
    });
  });

  // TigerTanda email-capture popup
  const ttModal = document.getElementById('tigertanda-modal');
  if (ttModal) {
    const form = ttModal.querySelector('#tt-modal-form') as HTMLFormElement;
    const emailInput = ttModal.querySelector('input[type="email"]') as HTMLInputElement;
    const errorEl = ttModal.querySelector('.tt-modal-error') as HTMLElement;
    const submitBtn = ttModal.querySelector('.tt-modal-primary') as HTMLButtonElement;
    let pendingUrl: string | null = null;

    const openModal = (url: string) => {
      pendingUrl = url;
      errorEl.hidden = true;
      errorEl.textContent = '';
      emailInput.value = '';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Subscribe & Download';
      ttModal.hidden = false;
      document.body.style.overflow = 'hidden';
      setTimeout(() => emailInput.focus(), 50);
    };

    const closeModal = () => {
      ttModal.hidden = true;
      pendingUrl = null;
      document.body.style.overflow = '';
    };

    const startDownload = (url: string | null) => {
      if (url) window.location.href = url;
    };

    document.querySelectorAll<HTMLAnchorElement>('.tigertanda-dl').forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        openModal(a.href);
      });
    });

    ttModal.querySelectorAll('[data-close]').forEach((el) => {
      el.addEventListener('click', closeModal);
    });

    ttModal.querySelector('[data-skip]')?.addEventListener('click', () => {
      const url = pendingUrl;
      closeModal();
      startDownload(url);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !ttModal.hidden) closeModal();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      if (!email) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Subscribing\u2026';
      errorEl.hidden = true;

      try {
        await fetch('/api/capture-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, productId: 'tigertanda' }),
        });
        const url = pendingUrl;
        closeModal();
        startDownload(url);
      } catch (err) {
        errorEl.textContent = 'Something went wrong. Please try again or skip.';
        errorEl.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = 'Subscribe & Download';
      }
    });
  }
</script>

