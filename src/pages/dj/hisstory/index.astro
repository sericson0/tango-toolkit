---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="Hisstory — Audio Restoration for Tango DJs" description="Hisstory removes hiss, clicks, and noise from vintage tango recordings while preserving the music. Download the free trial or purchase a license key.">
  <section class="product-hero">
    <div class="container hero-layout">
      <div class="hero-text">
        <a href="/" class="back-link">&larr; Back to Home</a>
        <h1>Hisstory</h1>
        <p class="hero-tagline">Keep the music, ditch the noise</p>
        <p class="hero-desc">Audio restoration for tango DJs. Remove hiss, clicks, and noise from vintage tango recordings while preserving the warmth and character of the music.</p>
        <div class="hero-actions">
          <a href="#download" class="btn btn-primary btn-lg">Download Free Trial</a>
          <a href="#purchase" class="btn btn-secondary btn-lg">Buy License</a>
        </div>
      </div>
      <div class="hero-logo">
        <img src="/images/hisstory-logo.png" alt="Hisstory - Keep the music, ditch the noise" />
      </div>
    </div>
  </section>

  <section class="features-section">
    <div class="container">
      <h2 class="section-heading">What It Does</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🔇</div>
          <h3>Remove Hiss & Noise</h3>
          <p>Eliminate background hiss and noise from old tango recordings without losing the music's character.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎵</div>
          <h3>Preserve the Music</h3>
          <p>Intelligent processing keeps the warmth, dynamics, and soul of the original recording intact.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔌</div>
          <h3>VST3 & Standalone</h3>
          <p>Use as a VST3 plugin in your DAW or as a standalone application. Works on Windows and macOS.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Real-Time Processing</h3>
          <p>Process audio in real-time. Preview your restored tracks instantly before exporting.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="how-it-works">
    <div class="container">
      <h2 class="section-heading">How It Works</h2>
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Download & Install</h3>
          <p>Download Hisstory and install it on your computer. The free trial gives you 2 days of full access.</p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>Try It Out</h3>
          <p>Load your tango recordings and hear the difference. All features are available during the trial.</p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>Purchase a License</h3>
          <p>When you're ready, purchase a license key. Enter your key in the app to unlock it permanently.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="download" class="download-section">
    <div class="container">
      <h2 class="section-heading">Download</h2>
      <p class="section-desc">Try Hisstory free for 2 days with full access to all features. No credit card required.</p>
      <div class="download-grid">
        <div class="download-card">
          <div class="download-icon">🪟</div>
          <h3>Windows</h3>
          <p>Windows 10 or later</p>
          <a href="https://github.com/sericson0/hisstory/releases/latest" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Download for Windows</a>
        </div>
        <div class="download-card">
          <div class="download-icon">🍎</div>
          <h3>macOS</h3>
          <p>macOS 11 (Big Sur) or later</p>
          <a href="https://github.com/sericson0/hisstory/releases/latest" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Download for macOS</a>
        </div>
      </div>
    </div>
  </section>

  <section id="purchase" class="purchase-section">
    <div class="container">
      <h2 class="section-heading">Purchase a License</h2>
      <div class="purchase-card">
        <div class="purchase-info">
          <h3>Hisstory License</h3>
          <p class="purchase-tagline">One-time purchase. Lifetime access.</p>
          <ul class="purchase-features">
            <li>Permanent license key — no subscription</li>
            <li>All future updates included</li>
            <li>VST3 plugin + standalone application</li>
            <li>Windows and macOS</li>
          </ul>
        </div>
        <div class="purchase-action">
          <div class="purchase-price">$40</div>
          <a href="#" id="buy-link" class="btn btn-primary btn-lg btn-purchase">Buy Now</a>
          <p class="purchase-note">Secure checkout via Stripe. Discount codes accepted at checkout. Your license key will be emailed to you after purchase.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <h2 class="section-heading">Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>How long is the free trial?</summary>
          <p>The trial lasts 2 days from first launch, with full access to all features. After the trial ends, you'll need a license key to continue using Hisstory.</p>
        </details>
        <details class="faq-item">
          <summary>How do I activate my license?</summary>
          <p>After purchasing, you'll receive a license key via email. Open Hisstory, click "Enter Key", paste your key, and click "Activate". That's it — no account or internet connection needed after activation.</p>
        </details>
        <details class="faq-item">
          <summary>Does it work as a VST plugin?</summary>
          <p>Yes! Hisstory works as a VST3 plugin in any compatible DAW (Virtual DJ, Ableton, Reaper, etc.) and also as a standalone application.</p>
        </details>
        <details class="faq-item">
          <summary>What platforms are supported?</summary>
          <p>Hisstory runs on Windows 10+ and macOS 11+ (Big Sur and later). Both Intel and Apple Silicon Macs are supported.</p>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .product-hero {
    padding: 3rem 0;
    background: linear-gradient(135deg, #1a0e00 0%, #2d1800 50%, #1a0e00 100%);
    border-bottom: 1px solid var(--color-orange-100);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (max-width: 768px) {
    .hero-layout {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-logo {
      order: -1;
      max-width: 20rem;
      margin: 0 auto;
    }
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: var(--color-orange-300);
  }

  .back-link:hover { color: var(--color-orange-200); }

  .product-hero h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-orange-400);
  }

  .hero-tagline {
    font-size: 1.3rem;
    font-style: italic;
    color: var(--color-orange-300);
    margin: 0 0 1rem;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--color-orange-100);
    margin: 0 0 1.5rem;
    max-width: 45ch;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero-desc { margin-left: auto; margin-right: auto; }
    .hero-actions { justify-content: center; }
  }

  .hero-logo img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    transition: background 0.2s, color 0.2s, transform 0.1s;
    text-decoration: none;
  }

  .btn-lg {
    padding: 0.75rem 1.5rem;
    font-size: 1.05rem;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    color: white;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.15);
    color: var(--color-orange-200);
    border: 1px solid var(--color-orange-400);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.25);
    color: white;
  }

  /* Features */
  .features-section {
    padding: 4rem 0;
  }

  .section-heading {
    text-align: center;
    margin: 0 0 2rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .feature-card {
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    text-align: center;
    transition: all 0.2s;
  }

  .feature-card:hover {
    border-color: var(--color-orange-300);
    box-shadow: var(--shadow-sm);
  }

  .feature-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  .feature-card p {
    margin: 0;
    color: var(--color-slate-600);
    font-size: 0.9rem;
  }

  /* How It Works */
  .how-it-works {
    padding: 4rem 0;
    background: var(--color-slate-50);
    border-top: 1px solid var(--color-slate-200);
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  .step {
    text-align: center;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .step h3 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  .step p {
    margin: 0;
    color: var(--color-slate-600);
    font-size: 0.9rem;
  }

  /* Download */
  .download-section {
    padding: 4rem 0;
  }

  .section-desc {
    text-align: center;
    color: var(--color-slate-600);
    margin: -1rem 0 2rem;
    font-size: 1rem;
  }

  .download-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    max-width: 36rem;
    margin: 0 auto;
  }

  .download-card {
    background: white;
    border: 2px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    transition: all 0.2s;
  }

  .download-card:hover {
    border-color: var(--color-orange-400);
    box-shadow: var(--shadow-md);
  }

  .download-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .download-card h3 {
    margin: 0 0 0.25rem;
    font-size: 1.15rem;
  }

  .download-card p {
    margin: 0 0 1.25rem;
    color: var(--color-slate-500);
    font-size: 0.85rem;
  }

  /* Purchase */
  .purchase-section {
    padding: 4rem 0;
    background: var(--color-slate-50);
    border-top: 1px solid var(--color-slate-200);
  }

  .purchase-card {
    max-width: 48rem;
    margin: 0 auto;
    background: white;
    border: 2px solid var(--color-orange-300);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
  }

  @media (max-width: 640px) {
    .purchase-card {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }

  .purchase-info h3 {
    margin: 0 0 0.25rem;
    font-size: 1.5rem;
  }

  .purchase-tagline {
    color: var(--color-orange-600);
    font-style: italic;
    margin: 0 0 1rem;
    font-size: 0.95rem;
  }

  .purchase-features {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .purchase-features li {
    padding: 0.3rem 0;
    color: var(--color-slate-600);
    font-size: 0.9rem;
  }

  .purchase-features li::before {
    content: "✓ ";
    color: var(--color-primary);
    font-weight: 700;
  }

  .purchase-action {
    text-align: center;
    min-width: 12rem;
  }

  .purchase-price {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-slate-900);
    margin-bottom: 1rem;
    font-family: var(--font-display);
  }

  .btn-purchase {
    width: 100%;
    text-align: center;
  }

  .purchase-note {
    margin: 0.75rem 0 0;
    font-size: 0.8rem;
    color: var(--color-slate-400);
  }

  /* FAQ */
  .faq-section {
    padding: 4rem 0;
  }

  .faq-list {
    max-width: 40rem;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-slate-200);
  }

  .faq-item summary {
    padding: 1rem 0;
    font-weight: 600;
    cursor: pointer;
    color: var(--color-slate-800);
    font-size: 1rem;
  }

  .faq-item summary:hover {
    color: var(--color-primary);
  }

  .faq-item p {
    margin: 0 0 1rem;
    color: var(--color-slate-600);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
</style>
