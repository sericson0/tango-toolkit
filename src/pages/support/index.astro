---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---

<BaseLayout title="Support — Tango Toolkit" description="Get help with Tango Toolkit software. Contact us for support, bug reports, or feature requests.">
  <PageHero title="Support" lead="We're here to help." />

  <section class="support-section">
    <div class="container">
      <div class="narrow">

        <!-- Ways to Get Help -->
        <h2>Ways to Get Help</h2>
        <div class="help-options">
          <div class="help-card">
            <span class="help-icon">&#9993;</span>
            <div>
              <strong>Email</strong>
              <p>Primary support channel. We typically respond within 24 hours.</p>
              <a href="mailto:tangotoolkit@gmail.com">tangotoolkit@gmail.com</a>
            </div>
          </div>
          <div class="help-card">
            <span class="help-icon">&#128214;</span>
            <div>
              <strong>Setup Guide</strong>
              <p>Step-by-step instructions for installing and configuring our software.</p>
              <a href="https://github.com/sericson0/TigerTango/blob/main/docs/sections/Installation.md" target="_blank" rel="noopener noreferrer">View setup guide</a>
            </div>
          </div>
          <div class="help-card">
            <span class="help-icon">&#10067;</span>
            <div>
              <strong>FAQ</strong>
              <p>Answers to common questions about licensing, compatibility, and more.</p>
              <a href="/dj/faq/">Browse the FAQ</a>
            </div>
          </div>
          <div class="help-card">
            <span class="help-icon">&#128187;</span>
            <div>
              <strong>GitHub</strong>
              <p>For bug reports and feature requests, visit the relevant repository.</p>
              <a href="https://github.com/sericson0" target="_blank" rel="noopener noreferrer">View repositories</a>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <hr />
        <h2>Send Us a Message</h2>

        <form name="support" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/support/?sent=1">
          <input type="hidden" name="form-name" value="support" />
          <p class="hidden-field"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="form-group">
            <label for="name">Name <span class="required">*</span></label>
            <input type="text" id="name" name="name" required placeholder="Your name" />
          </div>

          <div class="form-group">
            <label for="email">Email <span class="required">*</span></label>
            <input type="email" id="email" name="email" required placeholder="your@email.com" />
          </div>

          <div class="form-group">
            <label for="subject">Subject <span class="required">*</span></label>
            <select id="subject" name="subject" required>
              <option value="">Select a topic...</option>
              <option value="general">General question</option>
              <option value="license">Licensing / activation</option>
              <option value="bug">Bug report</option>
              <option value="feature">Feature request</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Message <span class="required">*</span></label>
            <textarea id="message" name="message" rows="5" required placeholder="Describe your question or issue..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-lg" id="support-btn">Send Message</button>
        </form>

        <div id="support-success" class="form-success" hidden>
          <span class="success-icon">&#10003;</span>
          <p><strong>Message sent!</strong> We typically respond within 24 hours.</p>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const supportForm = document.querySelector('form[name="support"]') as HTMLFormElement;
  const supportBtn = document.getElementById('support-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('support-success') as HTMLElement;

  // Show success message if returning after form submission
  if (new URLSearchParams(window.location.search).has('sent')) {
    if (supportForm) supportForm.hidden = true;
    if (successMsg) successMsg.hidden = false;
  }

  supportForm?.addEventListener('submit', () => {
    supportBtn.disabled = true;
    supportBtn.textContent = 'Sending\u2026';
  });
</script>

<style>
  .support-section {
    padding: 3rem 0;
  }

  .narrow {
    max-width: 36rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  h2 {
    font-size: 1.5rem;
    margin: 0 0 1.25rem;
  }

  /* Help Options */
  .help-options {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .help-card {
    display: flex;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    align-items: flex-start;
  }

  .help-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 0.15rem;
  }

  .help-card strong {
    display: block;
    font-size: 1rem;
    color: var(--color-slate-800);
    margin-bottom: 0.2rem;
  }

  .help-card p {
    margin: 0 0 0.35rem;
    font-size: 0.9rem;
    color: var(--color-slate-600);
    line-height: 1.5;
  }

  .help-card a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-primary);
  }

  .help-card a:hover {
    color: var(--color-primary-hover);
  }

  /* Form */
  .hidden-field {
    display: none;
  }

  form {
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.35rem;
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-slate-700);
  }

  .required {
    color: var(--color-orange-500);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-slate-300);
    border-radius: var(--radius-md);
    font-size: 0.95rem;
    font-family: inherit;
    background: var(--color-slate-50);
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-orange-400);
    box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
  }

  .form-success {
    text-align: center;
    padding: 2.5rem 2rem;
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
  }

  .success-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--color-orange-100);
    color: var(--color-orange-600);
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .form-success p {
    color: var(--color-slate-600);
    margin: 0;
  }
</style>
