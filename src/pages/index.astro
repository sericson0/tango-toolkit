---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products';
---

<BaseLayout title="Home" description="The Tango Toolkit - Tools and resources for tango DJs. Software, starter kits, and guides to elevate your tango DJing.">
  <section class="hero">
    <div class="container">
      <h1>Welcome to The Tango Toolkit</h1>
      <p class="hero-subtitle">The tools you need to elevate your tango.</p>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-grid">
        <a href="/dj/starter-kit/" class="cta-card">
          <div class="cta-icon">🚀</div>
          <h2>DJ Starter Kit</h2>
          <p>Everything you need to start tango DJing — software, music, and step-by-step guides.</p>
          <span class="cta-link">Get Started &rarr;</span>
        </a>
        <a href="/dj/software/" class="cta-card">
          <div class="cta-icon">💻</div>
          <h2>DJ Tools</h2>
          <p>Software and plugins built for tango DJs. Download free tools and pro-level utilities.</p>
          <span class="cta-link">Browse Tools &rarr;</span>
        </a>
        <a href="/dj/resources/" class="cta-card">
          <div class="cta-icon">📚</div>
          <h2>Discographies</h2>
          <p>Discographies, articles, and guides to deepen your knowledge of tango music.</p>
          <span class="cta-link">Explore Discographies &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="tools-section">
    <div class="container">
      <hr class="section-divider" />
      <h2 class="section-heading">DJ Tools</h2>
      <div class="tools-list">
        {products.map((product) => (
          <article class="tool-row">
            <div class="tool-info">
              <h3>{product.name}</h3>
              <p class="tool-tagline">{product.tagline}</p>
              <p class="tool-desc">{product.description}</p>
            </div>
            <div class="tool-side">
              {product.image && (
                <div class="tool-image">
                  <img src={product.image} alt={product.name} />
                </div>
              )}
              <div class="tool-actions">
                <a href={`/dj/software/#${product.id}`} class="btn btn-primary">
                  Get It Here &rarr;
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 5rem 0;
    background:
      linear-gradient(135deg, rgba(255,247,237,0.88) 0%, rgba(255,255,255,0.82) 50%, rgba(255,247,237,0.88) 100%),
      url('/images/Logo.png') center / 80% no-repeat;
    border-bottom: 1px solid var(--color-orange-100);
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 1rem;
    color: var(--color-slate-900);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-slate-600);
    max-width: 40ch;
    margin: 0;
  }

  /* CTA Cards */
  .cta-section {
    padding: 3rem 0;
  }

  .cta-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .cta-grid {
      grid-template-columns: 1fr;
    }
  }

  .cta-card {
    display: block;
    background: linear-gradient(180deg, var(--color-orange-50) 0%, white 100%);
    border: 2px solid var(--color-orange-400);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .cta-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .cta-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .cta-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.5rem;
  }

  .cta-card p {
    margin: 0 0 1.25rem;
    color: var(--color-slate-600);
    font-size: 0.95rem;
  }

  .cta-link {
    font-weight: 600;
    color: var(--color-primary);
    font-size: 1rem;
  }

  /* DJ Tools Section */
  .tools-section {
    padding: 0 0 4rem;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--color-slate-200);
    margin: 0 0 2rem;
  }

  .section-heading {
    margin: 0 0 2rem;
  }

  .tools-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .tool-row {
    display: flex;
    gap: 2rem;
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: all 0.2s;
  }

  .tool-row:hover {
    border-color: var(--color-orange-400);
    box-shadow: var(--shadow-md);
  }

  .tool-info {
    flex: 2;
    min-width: 0;
  }

  .tool-info h3 {
    margin: 0 0 0.25rem;
    font-size: 1.35rem;
  }

  .tool-tagline {
    font-style: italic;
    color: var(--color-orange-600);
    font-size: 0.9rem;
    margin: 0 0 0.75rem;
  }

  .tool-desc {
    margin: 0;
    color: var(--color-slate-600);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .tool-side {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    justify-content: center;
  }

  .tool-image {
    width: 100%;
    max-width: 240px;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-slate-100);
  }

  .tool-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .tool-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    max-width: 240px;
  }

  @media (max-width: 768px) {
    .tool-row {
      flex-direction: column;
    }

    .tool-side {
      align-items: flex-start;
    }

    .tool-image,
    .tool-actions {
      max-width: 100%;
    }
  }

</style>
