---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="The Tango Toolkit - Tools and resources for tango DJs. Software, starter kits, and guides to elevate your tango DJing.">
  <section class="hero">
    <div class="container">
      <h1>Welcome to The Tango Toolkit</h1>
      <p class="hero-subtitle">Tools and resources to elevate your tango DJing.</p>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <a href="/dj/" class="dj-cta-card">
        <div class="dj-cta-icon">🎵</div>
        <h2>DJ Resources</h2>
        <p>Courses, lessons, software, and tools for tango DJs. Beginner to advanced.</p>
        <span class="dj-cta-link">Explore DJ Resources &rarr;</span>
      </a>
    </div>
  </section>

  <section class="toolkit-section">
    <div class="container">
      <h2 class="section-heading">From the Toolkit</h2>
      <div class="toolkit-grid">
        <a href="/dj/starter-kit/" class="toolkit-card">
          <div class="toolkit-icon">🚀</div>
          <h3>DJ Starter Kit</h3>
          <p>Everything you need to start tango DJing — software, music, and step-by-step guides.</p>
          <span class="toolkit-link">Get Started &rarr;</span>
        </a>
        <a href="/dj/hisstory/" class="toolkit-card">
          <div class="toolkit-badge">Audio Restoration</div>
          <h3>Hisstory</h3>
          <p class="toolkit-tagline">Keep the Music, Ditch the Noise</p>
          <p>Remove hiss, clicks, and noise from vintage tango recordings while preserving the music.</p>
          <span class="toolkit-link">Learn More &rarr;</span>
        </a>
        <a href="/dj/software/" class="toolkit-card">
          <div class="toolkit-badge">Metadata</div>
          <h3>TigerTag</h3>
          <p class="toolkit-tagline">Tag Your Tango Tunes</p>
          <p>Batch-tag your tango music library with orchestra, singer, year, genre, and more.</p>
          <span class="toolkit-link">Learn More &rarr;</span>
        </a>
        <a href="/dj/software/" class="toolkit-card">
          <div class="toolkit-badge">Tanda Builder</div>
          <h3>TigerTanda</h3>
          <p class="toolkit-tagline">Find the tracks for the perfect tanda</p>
          <p>Intelligent tanda builder that suggests complementary tracks based on orchestra, era, and style.</p>
          <span class="toolkit-link">Learn More &rarr;</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 5rem 0;
    background:
      linear-gradient(135deg, rgba(255,247,237,0.88) 0%, rgba(255,255,255,0.82) 50%, rgba(255,247,237,0.88) 100%),
      url('/images/Logo.png') center / 80% no-repeat;
    border-bottom: 1px solid var(--color-orange-100);
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 1rem;
    color: var(--color-slate-900);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-slate-600);
    max-width: 40ch;
    margin: 0;
  }

  /* DJ Resources CTA */
  .cta-section {
    padding: 3rem 0;
  }

  .dj-cta-card {
    display: block;
    max-width: 36rem;
    margin: 0 auto;
    background: linear-gradient(180deg, var(--color-orange-50) 0%, white 100%);
    border: 2px solid var(--color-orange-400);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .dj-cta-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .dj-cta-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .dj-cta-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.75rem;
  }

  .dj-cta-card p {
    margin: 0 0 1.25rem;
    color: var(--color-slate-600);
    font-size: 1.05rem;
  }

  .dj-cta-link {
    font-weight: 600;
    color: var(--color-primary);
    font-size: 1.1rem;
  }

  /* Toolkit Products */
  .toolkit-section {
    padding: 3rem 0 4rem;
    background: var(--color-slate-50);
    border-top: 1px solid var(--color-slate-200);
  }

  .section-heading {
    text-align: center;
    margin: 0 0 2rem;
  }

  .toolkit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .toolkit-card {
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
    position: relative;
  }

  .toolkit-card:hover {
    border-color: var(--color-orange-400);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .toolkit-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .toolkit-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    background: var(--color-orange-100);
    color: var(--color-orange-800);
    margin-bottom: 0.75rem;
  }

  .toolkit-card h3 {
    margin: 0 0 0.25rem;
    font-size: 1.25rem;
  }

  .toolkit-tagline {
    font-style: italic;
    color: var(--color-orange-600);
    font-size: 0.9rem;
    margin: 0 0 0.75rem;
  }

  .toolkit-card p {
    margin: 0 0 1rem;
    color: var(--color-slate-600);
    font-size: 0.9rem;
  }

  .toolkit-link {
    font-weight: 600;
    color: var(--color-primary);
    font-size: 0.9rem;
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
</style>
