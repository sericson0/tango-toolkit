---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products';
---

<BaseLayout title="Home" description="The Tango Toolkit - Tools and resources for tango DJs. Software, starter kits, and guides to elevate your tango DJing.">
  <section class="hero">
    <div class="container">
      <h1>Welcome to The Tango Toolkit</h1>
      <p class="hero-subtitle"><strong>The tools you need to elevate your tango</strong> The Tango Tookit is an expanding collection of quality resources for tango. 
         It currently has tools and resources for tango DJs of all levels. Resources for tango dancers and organizers will be coming!</p>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-grid">
        <a href="/dj/starter-kit/" class="cta-card">
          <div class="cta-icon">🚀</div>
          <h2>DJ Starter Kit</h2>
          <p>Everything you need to start tango DJing — software, music, and step-by-step guides.</p>
          <span class="cta-link">Get Started &rarr;</span>
        </a>
        <a href="/dj/software/" class="cta-card">
          <div class="cta-icon">💻</div>
          <h2>DJ Tools</h2>
          <p>Software and plugins built for tango DJs. Download free tools and pro-level utilities.</p>
          <span class="cta-link">Browse Tools &rarr;</span>
        </a>
        <a href="/dj/resources/" class="cta-card">
          <div class="cta-icon">📚</div>
          <h2>Discographies</h2>
          <p>Discographies, articles, and guides to deepen your knowledge of tango music.</p>
          <span class="cta-link">Explore Discographies &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="engage-section">
    <div class="container">
      <div class="subscribe-bar">
        <div class="subscribe-text">
          <h2>Stay in the Loop</h2>
          <p>Get updates on new tools, features, and tango resources.</p>
        </div>
        <form class="subscribe-form" id="subscribeForm">
          <input type="email" id="subscribeEmail" placeholder="Your email address" required />
          <button type="submit" class="btn btn-primary" id="subscribeBtn">Subscribe</button>
        </form>
        <p class="subscribe-msg" id="subscribeMsg"></p>
      </div>
      <div class="support-bar">
        <button class="support-btn" id="openSupportModal">Help Support the Tango Toolkit</button>
      </div>
    </div>
  </section>

  <!-- Support Modal -->
  <div class="modal-overlay" id="supportModal">
    <div class="modal">
      <button class="modal-close" id="closeSupportModal">&times;</button>
      <h2>Help Support the Tango Toolkit</h2>
      <p class="modal-intro">Whether you'd like to contribute suggestions, resources, articles, software, or funds — every bit helps keep this project going.</p>

      <div class="modal-options">
        <div class="modal-option">
          <div class="modal-option-icon">&#9993;</div>
          <h3>Contribute</h3>
          <p>Share ideas, resources, articles, or software suggestions.</p>
          <a href="mailto:tangotoolkit@gmail.com" class="btn btn-primary">Email Us</a>
        </div>

        <div class="modal-option">
          <div class="modal-option-icon">&#9829;</div>
          <h3>Donate</h3>
          <p>Help fund development and keep the tools free.</p>
          <div class="donate-buttons">
            <a href="https://buy.stripe.com/5kQ8wOfGU7bsdZ9gplgnK01" target="_blank" rel="noopener" class="donate-link donate-stripe">
              <span>Card / Apple Pay</span>
            </a>
            <a href="https://venmo.com/Sean-Ericson-1" target="_blank" rel="noopener" class="donate-link donate-venmo">
              <span>Venmo</span>
            </a>
            <div class="donate-link donate-zelle">
              <span>Zelle</span>
              <span class="zelle-number">925-528-9221</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
  (function() {
    // Subscribe form
    var form = document.getElementById('subscribeForm');
    var emailInput = document.getElementById('subscribeEmail');
    var btn = document.getElementById('subscribeBtn');
    var msg = document.getElementById('subscribeMsg');

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = emailInput.value.trim();
      if (!email) return;

      btn.disabled = true;
      btn.textContent = 'Subscribing...';
      msg.textContent = '';
      msg.className = 'subscribe-msg';

      fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email })
      })
      .then(function(res) {
        if (!res.ok) throw new Error(res.statusText);
        return res.json();
      })
      .then(function() {
        msg.textContent = 'You\'re subscribed! Thanks for joining.';
        msg.className = 'subscribe-msg subscribe-success';
        emailInput.value = '';
      })
      .catch(function() {
        msg.textContent = 'Something went wrong. Please try again.';
        msg.className = 'subscribe-msg subscribe-error';
      })
      .finally(function() {
        btn.disabled = false;
        btn.textContent = 'Subscribe';
      });
    });

    // Support modal
    var modal = document.getElementById('supportModal');
    var openBtn = document.getElementById('openSupportModal');
    var closeBtn = document.getElementById('closeSupportModal');

    openBtn.addEventListener('click', function() {
      modal.classList.add('modal-open');
    });
    closeBtn.addEventListener('click', function() {
      modal.classList.remove('modal-open');
    });
    modal.addEventListener('click', function(e) {
      if (e.target === modal) modal.classList.remove('modal-open');
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') modal.classList.remove('modal-open');
    });
  })();
  </script>

  <section class="tools-section">
    <div class="container">
      <hr class="section-divider" />
      <h2 class="section-heading">DJ Tools</h2>
      <div class="tools-list">
        {products.map((product) => (
          <article class="tool-row">
            <div class="tool-info">
              <h3>{product.name}</h3>
              <p class="tool-tagline">{product.tagline}</p>
              <p class="tool-desc">{product.description}</p>
            </div>
            <div class="tool-side">
              {product.image && (
                <div class="tool-image">
                  <img src={product.image} alt={product.name} width="240" height="240" />
                </div>
              )}
              <div class="tool-actions">
                <a href={`/dj/software/#${product.id}`} class="btn btn-primary">
                  {product.price === 'Free' ? 'FREE! Get It Here' : 'Get It Here'} &rarr;
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 5rem 0;
    background:
      linear-gradient(135deg, rgba(255,247,237,0.88) 0%, rgba(255,255,255,0.82) 50%, rgba(255,247,237,0.88) 100%),
      url('/images/Logo.png') center / 80% no-repeat;
    border-bottom: 1px solid var(--color-orange-100);
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 1rem;
    color: var(--color-slate-900);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-slate-600);
    max-width: 40ch;
    margin: 0;
  }

  /* CTA Cards */
  .cta-section {
    padding: 3rem 0;
  }

  .cta-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .cta-grid {
      grid-template-columns: 1fr;
    }
  }

  .cta-card {
    display: block;
    background: linear-gradient(180deg, var(--color-orange-50) 0%, white 100%);
    border: 2px solid var(--color-orange-400);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .cta-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .cta-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .cta-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.5rem;
  }

  .cta-card p {
    margin: 0 0 1.25rem;
    color: var(--color-slate-600);
    font-size: 0.95rem;
  }

  .cta-link {
    font-weight: 600;
    color: var(--color-primary);
    font-size: 1rem;
  }

  /* DJ Tools Section */
  .tools-section {
    padding: 0 0 4rem;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--color-slate-200);
    margin: 0 0 2rem;
  }

  .section-heading {
    margin: 0 0 2rem;
  }

  .tools-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .tool-row {
    display: flex;
    gap: 2rem;
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: all 0.2s;
  }

  .tool-row:hover {
    border-color: var(--color-orange-400);
    box-shadow: var(--shadow-md);
  }

  .tool-info {
    flex: 2;
    min-width: 0;
  }

  .tool-info h3 {
    margin: 0 0 0.25rem;
    font-size: 1.35rem;
  }

  .tool-tagline {
    font-style: italic;
    color: var(--color-orange-600);
    font-size: 0.9rem;
    margin: 0 0 0.75rem;
  }

  .tool-desc {
    margin: 0;
    color: var(--color-slate-600);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .tool-side {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    justify-content: center;
  }

  .tool-image {
    width: 100%;
    max-width: 240px;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-slate-100);
  }

  .tool-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .tool-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    max-width: 240px;
  }

  @media (max-width: 768px) {
    .tool-row {
      flex-direction: column;
    }

    .tool-side {
      align-items: flex-start;
    }

    .tool-image,
    .tool-actions {
      max-width: 100%;
    }
  }

  /* Engage Section (Subscribe + Support) */
  .engage-section {
    padding: 0 0 1.5rem;
  }

  .subscribe-bar {
    background: linear-gradient(135deg, var(--color-orange-50) 0%, white 100%);
    border: 1px solid var(--color-orange-200);
    border-radius: var(--radius-lg);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .subscribe-text {
    flex: 1;
    min-width: 200px;
  }

  .subscribe-text h2 {
    margin: 0 0 0.25rem;
    font-size: 1.25rem;
  }

  .subscribe-text p {
    margin: 0;
    color: var(--color-slate-600);
    font-size: 0.95rem;
  }

  .subscribe-form {
    display: flex;
    gap: 0.5rem;
    flex: 1;
    min-width: 280px;
    max-width: 420px;
  }

  .subscribe-form input {
    flex: 1;
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--color-slate-300);
    border-radius: var(--radius-md);
    font-size: 0.95rem;
    font-family: 'Outfit', system-ui, sans-serif;
  }

  .subscribe-form input:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 1px;
    border-color: var(--color-accent);
  }

  .subscribe-form button {
    white-space: nowrap;
  }

  .subscribe-msg {
    width: 100%;
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    min-height: 1.2em;
  }
  .subscribe-msg:empty {
    display: none;
  }

  .subscribe-success {
    color: var(--color-green-700);
  }

  .subscribe-error {
    color: var(--color-red-600);
  }

  .support-bar {
    text-align: center;
    margin-top: 1rem;
  }

  .support-btn {
    background: var(--color-orange-500);
    border: none;
    border-radius: var(--radius-lg);
    padding: 0.85rem 2.5rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: white;
    cursor: pointer;
    font-family: 'Outfit', system-ui, sans-serif;
    transition: all 0.2s;
    box-shadow: 0 2px 8px rgba(249, 115, 22, 0.3);
  }

  .support-btn:hover {
    background: var(--color-orange-600);
    color: white;
    box-shadow: 0 4px 12px rgba(249, 115, 22, 0.4);
    transform: translateY(-1px);
  }

  /* Modal */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .modal-overlay.modal-open {
    display: flex;
  }

  .modal {
    background: white;
    border-radius: var(--radius-lg);
    padding: 2rem;
    max-width: 560px;
    width: 100%;
    position: relative;
    max-height: 90vh;
    overflow-y: auto;
  }

  .modal h2 {
    margin: 0 0 0.5rem;
    font-size: 1.5rem;
    padding-right: 2rem;
  }

  .modal-intro {
    margin: 0 0 1.5rem;
    color: var(--color-slate-600);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--color-slate-400);
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem;
  }

  .modal-close:hover {
    color: var(--color-slate-700);
  }

  .modal-options {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .modal-option {
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-md);
    padding: 1.25rem;
  }

  .modal-option-icon {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .modal-option h3 {
    margin: 0 0 0.25rem;
    font-size: 1.1rem;
  }

  .modal-option p {
    margin: 0 0 1rem;
    color: var(--color-slate-600);
    font-size: 0.9rem;
  }

  .donate-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .donate-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.6rem 1rem;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-md);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-slate-700);
    cursor: pointer;
    transition: all 0.15s;
    flex: 1;
    min-width: 100px;
    text-align: center;
  }

  .donate-link:hover {
    border-color: var(--color-primary);
    background: var(--color-orange-50);
  }

  .donate-stripe {
    border-color: #635bff;
    color: #635bff;
  }
  .donate-stripe:hover {
    background: #f5f4ff;
    border-color: #635bff;
  }

  .donate-venmo {
    border-color: #008cff;
    color: #008cff;
  }
  .donate-venmo:hover {
    background: #f0f8ff;
    border-color: #008cff;
  }

  .donate-zelle {
    border-color: #6c1cd3;
    color: #6c1cd3;
  }
  .donate-zelle:hover {
    background: #f6f0ff;
    border-color: #6c1cd3;
  }

  .zelle-number {
    font-weight: 400;
    font-size: 0.75rem;
    opacity: 0.8;
  }

  @media (max-width: 600px) {
    .subscribe-bar {
      padding: 1.25rem;
      gap: 1rem;
    }

    .subscribe-form {
      flex-direction: column;
      max-width: 100%;
    }

    .modal {
      padding: 1.5rem;
    }

    .donate-buttons {
      flex-direction: column;
    }
  }

</style>
